# Builder CRM - production environment
# Copy to `.env` in this directory and fill in generated secrets.
#   cp .env.example .env && chmod 600 .env
# NEVER commit the real .env.

APP_DOMAIN=builder.durwankur.com

# --- Database ---
POSTGRES_USER=buildercrm
POSTGRES_DB=buildercrm
# Generate:  openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_A_STRONG_PASSWORD

# --- Application ---
# JWT signing key. Generate:  openssl rand -hex 48
# Changing this invalidates every active session.
SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_KEY

# The AI calling loop must run in exactly ONE process.
# Leave 1 for a single backend instance.
RUN_AI_AGENT=1

# --- HireBuddha AI Calling Agent integration ---
# Master switch for outbound dispatch to the HireBuddha voice platform.
# Each workspace additionally chooses its provider (simulation | hirebuddha)
# in Raw Leads -> Configure.
HIREBUDDHA_ENABLED=1
# Shared secret HireBuddha presents when posting call results back to
# /api/v1/integrations/hirebuddha/... — generate and share it with the
# HireBuddha team (docs/HIREBUDDHA_INTEGRATION.md).
# Generate:  openssl rand -hex 32
HIREBUDDHA_CALLBACK_TOKEN=CHANGE_ME_GENERATE_A_CALLBACK_TOKEN
# Defaults are the Fortune company + Priya agent; override only if HireBuddha
# issues different ids.
#HIREBUDDHA_CLIENT_ID=3ffe9166-8dae-4488-a6a4-387dad47f3f7
#HIREBUDDHA_ENTITY_ID=65b0ec26-42c1-4a63-b03e-68692ee30c9b
